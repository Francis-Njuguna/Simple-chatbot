# =============================================================================
# Amref Help Desk RAG — environment configuration
# Copy this file to .env and fill in your real values before running.
#   cp .env.example .env
# =============================================================================

# Application
APP_NAME=Amref Help Desk RAG
APP_ENV=development
DEBUG=false
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
STREAMLIT_PORT=8501

# Security — CHANGE THIS to a long random string before running
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
RATE_LIMIT=30/minute

# =============================================================================
# Database — PostgreSQL running in Docker
# Start with: docker compose up postgres -d
# Tables are created automatically on first app startup.
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=amref
POSTGRES_PASSWORD=amref_secret
POSTGRES_DB=amref_helpdesk

# =============================================================================
# ChromaDB (vector store)
#
# CHROMA_MODE controls how the store is reached:
#   auto        (default) HttpClient if CHROMA_SERVER_HOST is set, else on-disk
#   persistent  always read the on-disk store at CHROMA_PERSIST_DIR
#   http        always connect to a standalone Chroma server
#
# Local dev / baked-image / Railway volume → persistent (leave CHROMA_MODE=auto
# and CHROMA_SERVER_HOST empty). CHROMA_PERSIST_DIR is where the vectors live;
# on a Railway volume set e.g. CHROMA_PERSIST_DIR=/data/chroma.
#
# Standalone Chroma service (e.g. a separate Railway service running the
# chromadb/chroma image) → set CHROMA_SERVER_HOST to its private hostname:
#   CHROMA_MODE=http
#   CHROMA_SERVER_HOST=chroma.railway.internal
#   CHROMA_SERVER_PORT=8000
#   CHROMA_SERVER_SSL=false
# =============================================================================
CHROMA_MODE=auto
CHROMA_SERVER_HOST=
CHROMA_SERVER_PORT=8000
CHROMA_SERVER_SSL=false
CHROMA_PERSIST_DIR=./data/chroma
# Legacy / compatibility (unused when CHROMA_SERVER_HOST is set):
CHROMA_HOST=localhost
CHROMA_PORT=8001

# =============================================================================
# LLM — Anthropic Claude (primary)
# Provider options: anthropic | openai | ollama
# =============================================================================
LLM_PROVIDER=anthropic

# Anthropic — get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here
# Fast + cheap:  claude-haiku-4-5
# Best quality:  claude-sonnet-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI (optional fallback — only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Ollama (optional local fallback — only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# =============================================================================
# Embeddings
# Provider options: ollama | sentence-transformers
#
# IMPORTANT: the vector store (data/chroma) is tied to the embedding model that
# built it. You MUST query with the SAME model you ingested with, or retrieval
# returns nothing / errors on dimension mismatch.
#   - Local with Ollama: nomic-embed-text (768-dim)
#   - Railway (NO Ollama): sentence-transformers all-MiniLM-L6-v2 (384-dim)
# => Ingest locally with the SAME provider your deployment uses before
#    committing data/chroma. For Railway, set EMBEDDING_PROVIDER=sentence-transformers
#    here AND on Railway, then re-run scripts/ingest.py.
# =============================================================================
#EMBEDDING_PROVIDER=ollama
#OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# sentence-transformers (used on Railway; also set this when ingesting for it)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# =============================================================================
# RAG pipeline settings
# =============================================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
TOP_K_IMAGES=3
MMR_DIVERSITY=0.3
RERANK_TOP_N=5

# Knowledge Base
KB_BASE_URL=https://helpdesk.amref.ac.ke
KB_INDEX_URL=https://helpdesk.amref.ac.ke/knowledgebase.php

# -----------------------------------------------------------------------------
# Crawler TLS
#
# The help-desk host often serves an INCOMPLETE certificate chain (missing
# intermediate CA), causing:
#   [SSL: CERTIFICATE_VERIFY_FAILED] unable to get local issuer certificate
#
# Recommended fix (stays secure): download the site's intermediate CA cert,
# save it as a PEM, and point KB_CA_BUNDLE at it. You can grab the full chain
# with:
#   openssl s_client -showcerts -servername helpdesk.amref.ac.ke \
#       -connect helpdesk.amref.ac.ke:443 </dev/null
# Copy the intermediate cert block into a file, e.g. ./certs/amref-chain.pem.
KB_CA_BUNDLE=
# Last-resort escape hatch: set to false to skip TLS verification for the
# crawler ONLY (insecure). Leave true unless you have no other option.
KB_VERIFY_SSL=true

# Paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
IMAGES_DIR=./data/images
STATIC_IMAGES_DIR=./backend/app/static/images

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
