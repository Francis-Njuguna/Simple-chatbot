# =============================================================================
# Amref Help Desk RAG — environment configuration
# Copy this file to .env and fill in your real values before running.
#   cp .env.example .env
# =============================================================================

# Application
APP_NAME=Amref Help Desk RAG
APP_ENV=development
DEBUG=false
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000
STREAMLIT_PORT=8501

# Security — CHANGE THIS to a long random string before running
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
RATE_LIMIT=30/minute

# =============================================================================
# Database — PostgreSQL running in Docker
# Start with: docker compose up postgres -d
# Tables are created automatically on first app startup.
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=amref
POSTGRES_PASSWORD=amref_secret
POSTGRES_DB=amref_helpdesk

# ChromaDB (vector store — persistent local directory)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./data/chroma

# =============================================================================
# LLM — Anthropic Claude (primary)
# Provider options: anthropic | openai | ollama
# =============================================================================
LLM_PROVIDER=anthropic

# Anthropic — get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here
# Fast + cheap:  claude-haiku-4-5
# Best quality:  claude-sonnet-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI (optional fallback — only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Ollama (optional local fallback — only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# =============================================================================
# Embeddings — Ollama nomic-embed-text (free, fast, local)
# Install: ollama pull nomic-embed-text
# Provider options: ollama | sentence-transformers
# =============================================================================
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# sentence-transformers fallback (only needed if EMBEDDING_PROVIDER=sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# =============================================================================
# RAG pipeline settings
# =============================================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
TOP_K_IMAGES=3
MMR_DIVERSITY=0.3
RERANK_TOP_N=5

# Knowledge Base
KB_BASE_URL=https://helpdesk.amref.ac.ke
KB_INDEX_URL=https://helpdesk.amref.ac.ke/knowledgebase.php

# Paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
IMAGES_DIR=./data/images
STATIC_IMAGES_DIR=./backend/app/static/images

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
