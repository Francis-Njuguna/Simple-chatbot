# ──────────────────────────────────────────────
# Node (not used, but guards against accidents)
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.yarn/
.npm/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ──────────────────────────────────────────────
# Large runtime data
# NOTE: data/chroma/ is intentionally NOT excluded here so that the
# pre-built ChromaDB vector store is baked into the Railway Docker image.
# On Railway (free tier) there are no persistent volume mounts, so the
# knowledge-base data must travel inside the image.
# ──────────────────────────────────────────────
data/raw/
data/processed/

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
*.log

