# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/

# Environment — keep the templates, never commit real secrets
.env
.env.local
# NOTE: .env.example and .env.railway.example are safe to commit (no real secrets)

# Raw / processed crawl data (large, re-generated by ingest script)
data/raw/
data/processed/

# NOTE: data/chroma/ is intentionally tracked so the pre-built vector store
# is available to Railway (which has no persistent volumes on the free plan).
# Re-run scripts/ingest.py locally and commit the updated data/chroma/ folder
# whenever the knowledge base changes.

# Logs
logs/
*.log

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Test
.pytest_cache/
.coverage
htmlcov/

# Docker
*.pid
